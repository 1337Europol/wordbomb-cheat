# Copie ce fichier en .env — ne jamais le committer

PORT=3000
NODE_ENV=production
TRUST_PROXY=true

# Rate limiting API
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Formulaire contact → e-mail du créateur (gratuit sur https://web3forms.com)
# 1. Entre ton adresse e-mail sur le site
# 2. Colle la access key ici — les messages arrivent dans ta boîte mail
WEB3FORMS_ACCESS_KEY=

# Contact — rate limit (IP + identifiant navigateur)
CONTACT_WINDOW_MS=3600000
CONTACT_MAX_PER_HOUR=5
